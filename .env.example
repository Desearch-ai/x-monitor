# Desearch API key — get yours at https://desearch.ai
DESEARCH_API_KEY=your_desearch_api_key_here

# OpenRouter API key — used by summarize.py for LLM summaries
# Get yours at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Discord bot token — used by post-to-discord.cjs
# Required if NOT running under OpenClaw (which auto-provides the token)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Social OS Supabase — optional live runtime config + runtime telemetry
# If absent, monitor.py still runs and logs telemetry as skipped.
SOCIAL_OS_SUPABASE_URL=https://your-project.supabase.co
SOCIAL_OS_SUPABASE_ANON_KEY=your_supabase_key_here

# Optional: mark scheduled monitor telemetry as cron instead of manual
# X_MONITOR_RUN_MODE=cron
